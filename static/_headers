# Cloudflare Pages headers config (Phase 3.6 P1-E2).
# Format: https://developers.cloudflare.com/pages/configuration/headers/

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: interest-cohort=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self'; worker-src 'self'; frame-ancestors 'none'

# Index files — long-cached, immutable. Bumping CACHE_NAME in sw.js
# invalidates the client-side Cache Storage; CDN cache is keyed by URL
# (which doesn't change), so we rely on the build-time hashes embedded
# in app chunks for HTML/JS/CSS busting and immutable cache here for
# the .msgpack.zst / .txt.zst payloads.
/indices/*
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: application/octet-stream

# Service Worker — must not be cached at the edge.
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Service-Worker-Allowed: /

# App shell — short cache; SvelteKit emits content-hashed asset names so
# the browser/edge can serve stale HTML safely while client requests
# updated chunks.
/
  Cache-Control: public, max-age=0, must-revalidate

# Hashed immutable assets emitted by Vite.
/_app/immutable/*
  Cache-Control: public, max-age=31536000, immutable
